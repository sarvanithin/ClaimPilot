{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://claimpilot-api-REPLACE.a.run.app/api/:path*"
    },
    {
      "source": "/fhir/:path*",
      "destination": "https://claimpilot-api-REPLACE.a.run.app/fhir/:path*"
    }
  ]
}
